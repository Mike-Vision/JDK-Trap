<ui:UiPage x:Class="JDKTrap.UI.Elements.Installer.Pages.WelcomePage"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
           xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
           xmlns:local="clr-namespace:JDKTrap.UI.Elements.Installer.Pages"
           xmlns:models="clr-namespace:JDKTrap.UI.ViewModels"
           xmlns:dmodels="clr-namespace:JDKTrap.UI.ViewModels.Installer"
           xmlns:resources="clr-namespace:JDKTrap.Resources"
           xmlns:controls="clr-namespace:JDKTrap.UI.Elements.Controls"
           mc:Ignorable="d" 
           d:DataContext="{d:DesignInstance dmodels:WelcomeViewModel, IsDesignTimeCreatable=True}"
           d:DesignHeight="450" d:DesignWidth="800"
           Title="WelcomePage"
           Scrollable="True"
           Loaded="UiPage_Loaded">

    <Grid Margin="0,0,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Description Block -->
        <Border Grid.Row="0" Margin="0,0,0,16" Padding="14,12" Background="#0CFFFFFF" BorderBrush="#14FFFFFF" BorderThickness="1" CornerRadius="8">
            <StackPanel>
                <controls:MarkdownTextBlock FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}" MarkdownText="{Binding MainText, Mode=OneWay}" TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0" FontSize="13" Foreground="{DynamicResource SystemAccentBrush}" Text="{x:Static resources:Strings.Installer_Welcome_NextToContinue}" TextWrapping="Wrap" Visibility="{Binding CanContinue, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </Border>

        <!-- Quick Links Header -->
        <TextBlock Grid.Row="1" Margin="2,0,0,10" FontWeight="SemiBold" FontSize="13.5" Text="Explore JDKTrap Resources:" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

        <!-- Cards Grid (2x2 layout) -->
        <UniformGrid Grid.Row="2" Columns="2" Rows="2" Margin="0,0,0,16">
            <!-- Card 1: Website -->
            <Button Click="WebsiteCard_Click" Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Margin="0,0,6,6">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#06FFFFFF" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="8" SnapsToDevicePixels="True">
                            <Grid Margin="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ui:SymbolIcon Symbol="Globe24" Filled="False" FontSize="18" Foreground="{DynamicResource SystemAccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="JDKTrap Website" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Visit the official project website." FontSize="10.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,1,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight24" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#12FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource SystemAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#04FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Card 2: Mods -->
            <Button Click="ModsCard_Click" Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Margin="6,0,0,6">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#06FFFFFF" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="8" SnapsToDevicePixels="True">
                            <Grid Margin="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ui:SymbolIcon Symbol="Grid24" Filled="False" FontSize="18" Foreground="{DynamicResource SystemAccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Roblox/JDKTrap Mods" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Explore modifications &amp; settings." FontSize="10.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,1,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight24" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#12FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource SystemAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#04FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Card 3: Crosshairs -->
            <Button Click="CrosshairsCard_Click" Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Margin="0,6,6,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#06FFFFFF" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="8" SnapsToDevicePixels="True">
                            <Grid Margin="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ui:SymbolIcon Symbol="Target24" Filled="False" FontSize="18" Foreground="{DynamicResource SystemAccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Crosshairs" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Custom target crosshair overlays." FontSize="10.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,1,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight24" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#12FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource SystemAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#04FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Card 4: Documentation -->
            <Button Click="DocumentationCard_Click" Padding="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Margin="6,6,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#06FFFFFF" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="8" SnapsToDevicePixels="True">
                            <Grid Margin="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ui:SymbolIcon Symbol="Document24" Filled="False" FontSize="18" Foreground="{DynamicResource SystemAccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Documentation" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="Read features &amp; resolution guides." FontSize="10.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,1,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight24" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#12FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource SystemAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#04FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </UniformGrid>

        <!-- Footer Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
            <ui:Button Content="Donate"
                       Icon="Heart24"
                       Margin="0,0,8,0"
                       Padding="12,6"
                       Click="DonateButton_Click" />

            <ui:Button Content="Contributors"
                       Icon="People24"
                       Padding="12,6"
                       Click="ContributorsButton_Click" />
        </StackPanel>
    </Grid>
</ui:UiPage>