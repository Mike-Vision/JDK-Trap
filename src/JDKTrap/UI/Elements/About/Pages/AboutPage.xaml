<ui:UiPage
    x:Class="JDKTrap.UI.Elements.About.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:JDKTrap.UI.Elements.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dmodels="clr-namespace:JDKTrap.UI.ViewModels.About"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:JDKTrap.UI.ViewModels"
    xmlns:resources="clr-namespace:JDKTrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="AboutPage"
    d:DataContext="{d:DesignInstance dmodels:AboutViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1500"
    d:DesignWidth="800"
    KeyDown="UiPage_KeyDown"
    Scrollable="True"
    mc:Ignorable="d">
    <ui:UiPage.Resources>
        <Storyboard x:Key="EggStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="Image1"
                Storyboard.TargetProperty="Opacity"
                From="1.0"
                To="0.0"
                Duration="0:0:3" />
            <DoubleAnimation
                Storyboard.TargetName="Image2"
                Storyboard.TargetProperty="Opacity"
                From="0.0"
                To="1.0"
                Duration="0:0:3" />
        </Storyboard>
    </ui:UiPage.Resources>

    <StackPanel Margin="0,0,14,14">

        <Grid Margin="0,0,0,24" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image
                x:Name="Image1"
                Grid.Column="0"
                Width="72"
                Height="72"
                VerticalAlignment="Center"
                RenderOptions.BitmapScalingMode="HighQuality"
                Source="pack://application:,,,/JDKTrap.ico" />
            <Image
                x:Name="Image2"
                Grid.Column="0"
                Width="72"
                Height="72"
                VerticalAlignment="Center"
                Opacity="0"
                RenderOptions.BitmapScalingMode="HighQuality"
                Source="pack://application:,,,/Resources/BootstrapperStyles/ByfronDialog/Matt.png" />

            <StackPanel
                Grid.Column="1"
                Margin="12,0,0,0"
                VerticalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Margin="0,0,4,0"
                        FontSize="24"
                        FontWeight="Medium"
                        Text="JDKTrap" />

                </Grid>
                <TextBlock Text="A Simple yet Advanced, Bloxstrap Fork." />
            </StackPanel>
        </Grid>

        <WrapPanel HorizontalAlignment="Center"
           Orientation="Horizontal"
           ItemHeight="40"
           ItemWidth="Auto">

            <ui:Anchor
                Margin="0,0,8,0"
                Content="{x:Static resources:Strings.Menu_About_ReportIssue}"
                Icon="BookExclamationMark24"
                NavigateUri="https://github.com/Mike-Vision/JDK-Trap/issues" />
            <ui:Anchor
                Margin="0,0,8,0"
                Content="Website"
                Icon="Globe20"
                NavigateUri="https://boisterous-souffle-33150b.netlify.app" />
            <ui:Anchor
                Click="Anchor_Click"
                Content="{x:Static resources:Strings.Menu_About_DiscordServer}"
                Icon="Chat48"
                NavigateUri="https://discord.gg/X3CRTP66VG" />
        </WrapPanel>

        <TextBlock
            Margin="0,16,0,0"
            FontFamily="Segoe UI Semibold"
            FontSize="20"
            FontWeight="Medium"
            Text="Lead Developer" />

        <TextBlock
            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
            Text="The creator and lead developer of JDKTrap."
            TextWrapping="Wrap" />

        <StackPanel Orientation="Vertical" Margin="0,8,0,0">

            <ui:Card Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Image
                        Width="48"
                        Height="48"
                        VerticalAlignment="Top"
                        Source="https://avatars.githubusercontent.com/u/251816064?v=4"/>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Mike-Vision"/>

                        <TextBlock
                            Opacity="0.7"
                            Text="Lead Developer &amp; Owner of JDKTrap."/>
                    </StackPanel>
                </Grid>
            </ui:Card>

        </StackPanel>

        <TextBlock
            Margin="0,16,0,0"
            FontFamily="Segoe UI Semibold"
            FontSize="20"
            FontWeight="Medium"
            Text="{x:Static resources:Strings.Menu_About_Contributors}" />
        <TextBlock
            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
            Text="These are the people who have made notable contributions to JDKTrap, helping make it what it is."
            TextWrapping="Wrap" />
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <controls:Expander
                Grid.Column="0"
                Margin="0,0,4,0"
                BorderThickness="2,2,2,2"
                HeaderIcon="Code24"
                HeaderText="Coders"
                IsExpanded="False">
                <ItemsControl ItemsSource="{Binding Coders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:MarkdownTextBlock MarkdownText="{Binding MarkdownText}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </controls:Expander>

            <controls:Expander
                Grid.Column="1"
                Margin="4,0,4,0"
                BorderThickness="2,2,2,2"
                HeaderIcon="AppsAddIn28"
                HeaderText="Contribution"
                IsExpanded="False">
                <ItemsControl ItemsSource="{Binding Contributors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:MarkdownTextBlock MarkdownText="{Binding MarkdownText}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </controls:Expander>

            <controls:Expander
                Grid.Column="2"
                Margin="4,0,0,0"
                BorderThickness="2,2,2,2"
                HeaderIcon="Heart20"
                HeaderText="Inspirations"
                IsExpanded="False">
                <StackPanel>
                    <controls:MarkdownTextBlock MarkdownText="[Fishstrap](https://github.com/returnrqt/)" />
                    <controls:MarkdownTextBlock MarkdownText="[Bloxstrap](https://github.com/MaximumADHD)" />
                    <controls:MarkdownTextBlock MarkdownText="[Froststrap](https://github.com/RealMeddsam/Froststrap)" />
                    <controls:MarkdownTextBlock MarkdownText="[MaximumADHD](https://github.com/BloxstrapLabs)" />
                    <controls:MarkdownTextBlock MarkdownText="[Multako](https://www.roblox.com/users/2485612194/profile)" />
                    <controls:MarkdownTextBlock MarkdownText="[axstin](https://github.com/axstin)" />
                    <controls:MarkdownTextBlock MarkdownText="[Mantaraix](https://github.com/Mantaraix)" />
                    <controls:MarkdownTextBlock MarkdownText="[apprehensions](https://github.com/apprehensions)" />
                    <controls:MarkdownTextBlock MarkdownText="[axellse](https://github.com/axellse)" />
                    <controls:MarkdownTextBlock MarkdownText="[NetSoftworks](https://github.com/netsoftwork)" />
                    <controls:MarkdownTextBlock MarkdownText="[BlueOutside](https://github.com/BlueOutside)" />
                    <controls:MarkdownTextBlock MarkdownText="[Naveandice](https://github.com/Naveandice)" />
                    <controls:MarkdownTextBlock MarkdownText="[Skylan](https://github.com/Skylan031)" />
                    <controls:MarkdownTextBlock MarkdownText="[Xaurchark](https://github.com/nicolasfp1)" />
                    <controls:MarkdownTextBlock MarkdownText="[c_llie](https://discord.com/users/1053052072779583488)" />
                </StackPanel>
            </controls:Expander>
        </Grid>

        <StackPanel Visibility="{Binding BuildInformationVisibility, Mode=OneTime}">
            <TextBlock
                Margin="0,16,0,0"
                FontFamily="Segoe UI Semibold"
                FontSize="20"
                Text="Build Information" />

            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
        Grid.Row="0"
        Grid.Column="0"
        FontSize="14"
        FontWeight="Medium"
        Text="Updated:"
        VerticalAlignment="Center"
        Margin="0,0,8,0" />

                <TextBlock
        Grid.Row="0"
        Grid.Column="1"
        FontSize="14"
        Text="{Binding BuildTimestamp, Mode=OneTime}"
        VerticalAlignment="Center" />

                <TextBlock
        Grid.Row="1"
        Grid.Column="0"
        FontSize="14"
        FontWeight="Medium"
        Text="Version:"
        VerticalAlignment="Center"
        Margin="0,4,8,0" />

                <TextBlock
        Grid.Row="1"
        Grid.Column="1"
        FontSize="14"
        Text="{Binding Version, Mode=OneTime}"
        VerticalAlignment="Center" />

                <TextBlock
        Grid.Row="2"
        Grid.Column="0"
        FontSize="14"
        FontWeight="Medium"
        Text="Commit Hash:"
        Visibility="{Binding BuildCommitVisibility, Mode=OneTime}"
        VerticalAlignment="Center"
        Margin="0,4,8,0" />

                <TextBlock
        Grid.Row="2"
        Grid.Column="1"
        FontSize="14"
        Text="{Binding CommitHash, Mode=OneTime}"
        Visibility="{Binding BuildCommitVisibility, Mode=OneTime}"
        VerticalAlignment="Center" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,0,0,4"
                    VerticalAlignment="Bottom"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Visibility="{Binding BuildCommitVisibility, Mode=OneTime}">
                    <Hyperlink
                        Command="models:GlobalViewModel.OpenWebpageCommand"
                        CommandParameter="{Binding BuildCommitHashUrl, Mode=OneTime}"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                        <TextBlock Text="{Binding BuildMetadata.CommitHash, Mode=OneTime}" />
                    </Hyperlink>
                </TextBlock>

                <TextBlock
                    Grid.Row="3"
                    Grid.Column="0"
                    Margin="0,4,16,4"
                    FontSize="14"
                    FontWeight="Medium"
                    Text="Commit Ref"
                    Visibility="{Binding BuildCommitVisibility, Mode=OneTime}" />
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,0,0,4"
                    VerticalAlignment="Bottom"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Text="{Binding BuildMetadata.CommitRef, Mode=OneTime}"
                    Visibility="{Binding BuildCommitVisibility, Mode=OneTime}" />
            </Grid>
        </StackPanel>
    </StackPanel>
</ui:UiPage>
